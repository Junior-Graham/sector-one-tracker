          </p>
        </div>
      </header>

      <main className="max-w-5xl mx-auto px-5 py-14">
        {tab === "global" ? (
          <GlobalBoard />
        ) : group ? (
          <GroupDashboard
            group={group}
            adminKey={adminKey}
            onLeave={() => { setGroup(null); setAdminKey(null); }}
          />
        ) : (
          <div>
            <div className="flex items-center gap-2 mb-1 text-slate-500 font-mono text-xs tracking-[0.2em]">
              <Lock size={13} /> PRIVATE
            </div>
            <h2 className="font-display text-2xl text-white mb-6">MY GROUP</h2>
            <GroupSetup onEnter={(g, key) => { setGroup(g); setAdminKey(key); }} />
          </div>
        )}
