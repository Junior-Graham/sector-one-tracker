          <div className="flex gap-1 border border-slate-800 p-1">
            <button
              onClick={() => setTab("global")}
              className={`px-3 py-1.5 text-xs font-mono tracking-wide transition-colors ${tab === "global" ? "bg-cyan-400 text-slate-950" : "text-slate-400 hover:text-white"}`}
            >
              GLOBAL
            </button>
            <button
              onClick={() => setTab("group")}
              className={`px-3 py-1.5 text-xs font-mono tracking-wide transition-colors ${tab === "group" ? "bg-cyan-400 text-slate-950" : "text-slate-400 hover:text-white"}`}
