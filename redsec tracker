        <div className="max-w-5xl mx-auto px-5 pt-14 pb-16 relative">
          <div className="text-cyan-400 font-mono text-xs tracking-[0.3em] mb-4">REDSEC // BATTLE ROYALE INTEL</div>
          <h1 className="font-display text-white text-4xl sm:text-5xl leading-[0.95] mb-4 max-w-2xl">
            EVERY DROP. EVERY KILL. <span className="text-cyan-400">LOGGED.</span>
          </h1>
          <p className="text-slate-400 max-w-md">
